# ============================================================
# DASH CRM - Variables de Entorno (PLANTILLA)
# ============================================================
# Copiá este archivo como .env y completá con tus valores:
#   cp .env.example .env
# ============================================================

# Entorno: development | staging | production
APP_ENV=production
APP_NAME="DASH"
APP_VERSION="1.0.0"
APP_URL=https://dashtienda.com

# Google Identity Services (OAuth)
GOOGLE_CLIENT_ID=

# Mostrar errores solo en development
APP_DEBUG=false

# ============================================================
# BASE DE DATOS
# ============================================================
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=dash_crm
DB_USER=root
DB_PASS=
DB_CHARSET=utf8mb4

# ============================================================
# SESIONES
# ============================================================
SESSION_SECURE=true         # true en producción (HTTPS)
SESSION_HTTPONLY=true
SESSION_LIFETIME=7200       # segundos (2 horas)

# ============================================================
# ZONA HORARIA
# ============================================================
APP_TIMEZONE=America/Argentina/Buenos_Aires
